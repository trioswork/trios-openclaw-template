# OpenClaw Agent Template, local environment example.
# Copy to .env and fill locally. Never commit .env.

# LLM provider, fill at least one according to your model setup.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ZAI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Optional embeddings provider.
# GEMINI_API_KEY=

# PostgreSQL memory database.
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=agent_memory
PG_USER=agent
PG_PASSWORD=change-me

# Optional private GitHub backup target.
# GITHUB_BACKUP_TOKEN=
# GITHUB_BACKUP_OWNER=
# GITHUB_BACKUP_REPO=
